#!/usr/bin/env bash
#MISE description="Compile local binaries."
#USAGE flag "--target <target>" default="all" help="Target platform: all, linux-x64, macos-arm64, or windows-x64" {
#USAGE   choices "all" "linux-x64" "macos-arm64" "windows-x64"
#USAGE }

set -euo pipefail

compile_linux() {
  bun build --compile --target=bun-linux-x64 \
    --outfile=dist/kuebiko-linux-x64 \
    src/index.ts
}

compile_macos() {
  bun build --compile --target=bun-darwin-arm64 \
    --outfile=dist/kuebiko-macos-arm64 \
    src/index.ts
}

compile_windows() {
  bun build --compile --target=bun-windows-x64 \
    --outfile=dist/kuebiko-windows-x64.exe \
    src/index.ts
}

case "${usage_target:-all}" in
  all)
    compile_linux
    compile_macos
    compile_windows
    ;;
  linux-x64)
    compile_linux
    ;;
  macos-arm64)
    compile_macos
    ;;
  windows-x64)
    compile_windows
    ;;
esac
